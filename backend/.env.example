# Path to your default trades Excel file
DEFAULT_TRADES_PATH=/path/to/your/Trades.xlsx

# Journal storage path (default: data/journal.json)
# JOURNAL_PATH=data/journal.json

# Finnhub API key (free tier: 60 calls/min) — fallback news provider
# Get yours at https://finnhub.io/register
# FINNHUB_API_KEY=your_finnhub_api_key_here

# Massive.com API key — primary data provider for Sector Rotation, the
# Qullamaggie breakout screener, RSI, calendar (earnings/ex-div), and news.
# Get yours at https://massive.com
# MASSIVE_API_KEY=your_massive_api_key_here

# Data provider switch for OHLCV (default: massive; fallback: yahoo)
# QF_DATA_PROVIDER=massive

# News provider switch (default: massive; fallback: finnhub)
# QF_NEWS_PROVIDER=massive

# Anthropic API key — needed for AI-powered stock criteria analysis
# Get yours at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Interactive Brokers (optional — only needed for Bot Trader)
# IB_HOST=127.0.0.1
# IB_PORT=7497
# IB_CLIENT_ID=1
# IB_PAPER=true
